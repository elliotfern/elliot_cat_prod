{
  "compilerOptions": {
    "target": "es2021",
    "lib": ["DOM", "DOM.Iterable", "ES2021"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": false,
    "outDir": "./dist",
    "rootDir": "./src/",
    "sourceMap": false,

    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["./node_modules/@types", "src/frontend/types"]
      },

 "include": [
    "src",
    "src/types/**/*.d.ts"
  ], 
  "exclude": ["node_modules"],
}

